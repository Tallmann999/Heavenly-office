  - Key: soul.dobry_starik.name
    Value: "\u0414\u043E\u0431\u0440\u044B\u0439 \u0441\u0442\u0430\u0440\u0438\u043A"
  - Key: soul.dobry_starik.summary
    Value: "\u041F\u0440\u043E\u0436\u0438\u043B \u0447\u0435\u0441\u0442\u043D\u0443\u044E
      \u0436\u0438\u0437\u043D\u044C, \u043F\u043E\u043C\u043E\u0433\u0430\u043B
      \u0441\u043E\u0441\u0435\u0434\u044F\u043C."
  - Key: soul.dobry_starik.good_1
    Value: "\u041A\u043E\u0440\u043C\u0438\u043B \u0431\u0435\u0437\u0434\u043E\u043C\u043D\u044B\u0445"
  - Key: soul.dobry_starik.bad_1
    Value: "\u0418\u043D\u043E\u0433\u0434\u0430 \u0432\u043E\u0440\u043E\u0432\u0430\u043B
      \u044F\u0431\u043B\u043E\u043A\u0438"
  - Key: soul.greedy_merchant.name
    Value: "\u0416\u0430\u0434\u043D\u044B\u0439 \u043A\u0443\u043F\u0435\u0446"
  - Key: soul.greedy_merchant.summary
    Value: "\u0417\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435,
      \u043E\u0431\u043C\u0430\u043D\u044B\u0432\u0430\u044F \u043A\u043B\u0438\u0435\u043D\u0442\u043E\u0432."
  - Key: soul.greedy_merchant.good_1
    Value: "\u041F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043B \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
      \u0440\u044B\u043D\u043E\u043A"
  - Key: soul.greedy_merchant.bad_1
    Value: "\u041E\u0431\u043C\u0430\u043D\u044B\u0432\u0430\u043B \u0432 \u0432\u0435\u0441\u0430\u0445"
  - Key: soul.soldier_repented.name
    Value: "\u0421\u043E\u043B\u0434\u0430\u0442 \u0441 \u0440\u0430\u0441\u043A\u0430\u044F\u043D\u0438\u0435\u043C"
  - Key: soul.soldier_repented.summary
    Value: "\u0423\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u0431\u043E\u044F\u0445,
      \u043F\u043E\u0437\u0436\u0435 \u0438\u0441\u043A\u0430\u043B \u0438\u0441\u043A\u0443\u043F\u043B\u0435\u043D\u0438\u044F."
  - Key: soul.archive_error.name
    Value: "\u0410\u0440\u0445\u0438\u0432\u043D\u0430\u044F \u043E\u0448\u0438\u0431\u043A\u0430"
  - Key: soul.archive_error.summary
    Value: "\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442
