  - Key: soul.reptiloid_taxman.name
    Value: "\u0420\u0435\u043F\u0442\u0438\u043B\u043E\u0438\u0434-\u043D\u0430\u043B\u043E\u0433\u043E\u0432\u0438\u043A"
  - Key: soul.reptiloid_taxman.summary
    Value: "\u0421\u0443\u0440\u043E\u0432\u044B\u0439 \u0441\u0431\u043E\u0440\u0449\u0438\u043A
